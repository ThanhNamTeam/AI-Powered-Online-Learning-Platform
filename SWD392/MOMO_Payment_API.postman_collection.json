{
    "info": {
        "name": "MOMO Payment API",
        "description": "Collection for testing MOMO payment integration",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Create Payment - BASIC Plan",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{accessToken}}",
                        "description": "Replace with your JWT token"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"subscriptionPlan\": \"BASIC\",\n  \"amount\": 100000,\n  \"orderInfo\": \"BASIC Subscription - 1 Month\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8080/identity/payment/create",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "identity",
                        "payment",
                        "create"
                    ]
                },
                "description": "Create a payment for BASIC subscription (100,000 VND)"
            }
        },
        {
            "name": "2. Create Payment - PREMIUM Plan",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{accessToken}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"subscriptionPlan\": \"PREMIUM\",\n  \"amount\": 500000,\n  \"orderInfo\": \"PREMIUM Subscription - 1 Month\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8080/identity/payment/create",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "identity",
                        "payment",
                        "create"
                    ]
                },
                "description": "Create a payment for PREMIUM subscription (500,000 VND)"
            }
        },
        {
            "name": "3. Create Payment - ENTERPRISE Plan",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{accessToken}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"subscriptionPlan\": \"ENTERPRISE\",\n  \"amount\": 2000000,\n  \"orderInfo\": \"ENTERPRISE Subscription - 1 Month\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8080/identity/payment/create",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "identity",
                        "payment",
                        "create"
                    ]
                },
                "description": "Create a payment for ENTERPRISE subscription (2,000,000 VND)"
            }
        },
        {
            "name": "4. Get Payment by ID",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{accessToken}}"
                    }
                ],
                "url": {
                    "raw": "http://localhost:8080/identity/payment/{{paymentId}}",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "identity",
                        "payment",
                        "{{paymentId}}"
                    ]
                },
                "description": "Get payment details by payment ID. Replace {{paymentId}} with actual UUID."
            }
        },
        {
            "name": "5. Get My Payment History",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{accessToken}}"
                    }
                ],
                "url": {
                    "raw": "http://localhost:8080/identity/payment/my-payments",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "identity",
                        "payment",
                        "my-payments"
                    ]
                },
                "description": "Get all payments for the current authenticated user"
            }
        },
        {
            "name": "6. MOMO Callback (Simulate)",
            "request": {
                "method": "POST",
                "header": [],
                "url": {
                    "raw": "http://localhost:8080/identity/payment/momo/callback?partnerCode=MOMOLRJZ20181206&orderId={{orderId}}&requestId={{requestId}}&amount=500000&orderInfo=PREMIUM Subscription&orderType=momo_wallet&transId=123456789&resultCode=0&message=Success&payType=qr&responseTime=1234567890&extraData=&signature={{signature}}",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "identity",
                        "payment",
                        "momo",
                        "callback"
                    ],
                    "query": [
                        {
                            "key": "partnerCode",
                            "value": "MOMOLRJZ20181206"
                        },
                        {
                            "key": "orderId",
                            "value": "{{orderId}}",
                            "description": "Transaction ID from payment creation"
                        },
                        {
                            "key": "requestId",
                            "value": "{{requestId}}"
                        },
                        {
                            "key": "amount",
                            "value": "500000"
                        },
                        {
                            "key": "orderInfo",
                            "value": "PREMIUM Subscription"
                        },
                        {
                            "key": "orderType",
                            "value": "momo_wallet"
                        },
                        {
                            "key": "transId",
                            "value": "123456789"
                        },
                        {
                            "key": "resultCode",
                            "value": "0",
                            "description": "0 = success, other = failed"
                        },
                        {
                            "key": "message",
                            "value": "Success"
                        },
                        {
                            "key": "payType",
                            "value": "qr"
                        },
                        {
                            "key": "responseTime",
                            "value": "1234567890"
                        },
                        {
                            "key": "extraData",
                            "value": ""
                        },
                        {
                            "key": "signature",
                            "value": "{{signature}}",
                            "description": "HMAC-SHA256 signature (will be verified)"
                        }
                    ]
                },
                "description": "Simulate MOMO callback. Note: This is normally called by MOMO, not manually. Signature verification will fail unless you generate a valid signature."
            }
        }
    ],
    "variable": [
        {
            "key": "accessToken",
            "value": "your-jwt-token-here",
            "type": "string"
        },
        {
            "key": "paymentId",
            "value": "payment-uuid-here",
            "type": "string"
        },
        {
            "key": "orderId",
            "value": "order-uuid-here",
            "type": "string"
        },
        {
            "key": "requestId",
            "value": "request-uuid-here",
            "type": "string"
        },
        {
            "key": "signature",
            "value": "signature-here",
            "type": "string"
        }
    ]
}